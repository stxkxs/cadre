# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cadre
DB_POOL_SIZE=10

# Auth (GitHub OAuth)
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret
AUTH_GITHUB_ID=your-github-oauth-app-id
AUTH_GITHUB_SECRET=your-github-oauth-app-secret

# Encryption (for API key storage)
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=your-encryption-secret

# App
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development
CADRE_ENV=local
LOG_LEVEL=debug

# AWS (Bedrock + S3)
AWS_REGION=us-east-1
S3_BUCKET=cadre-artifacts
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=

# Redis
REDIS_URL=redis://localhost:6379

# Webhooks
WEBHOOK_BASE_URL=http://localhost:3000/api/webhooks
WEBHOOK_SECRET=your-webhook-hmac-secret

# Integration OAuth (uncomment and configure as needed)
# GITHUB_INTEGRATION_CLIENT_ID=
# GITHUB_INTEGRATION_CLIENT_SECRET=
# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# FIGMA_CLIENT_ID=
# FIGMA_CLIENT_SECRET=
# JIRA_CLIENT_ID=
# JIRA_CLIENT_SECRET=
# CONFLUENCE_CLIENT_ID=
# CONFLUENCE_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# LOOM_CLIENT_ID=
# LOOM_CLIENT_SECRET=
# CODA_CLIENT_ID=
# CODA_CLIENT_SECRET=

# Per-integration webhook secrets (optional, falls back to WEBHOOK_SECRET)
# WEBHOOK_SECRET_GITHUB=
# WEBHOOK_SECRET_LINEAR=
# WEBHOOK_SECRET_SLACK=
# WEBHOOK_SECRET_FIGMA=
# WEBHOOK_SECRET_JIRA=
# WEBHOOK_SECRET_LOOM=
# WEBHOOK_SECRET_CODA=
